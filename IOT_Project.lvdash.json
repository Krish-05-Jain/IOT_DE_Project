{
  "datasets": [
    {
      "name": "5d4417f9",
      "displayName": "Hourly Temperature Trends from Device Health Data",
      "queryLines": [
        "SELECT\n",
        "    reading_hour,\n",
        "    AVG(avg_temperature) AS avg_temp\n",
        "FROM iot_krish.gold.hourly_device_health\n",
        "GROUP BY reading_hour\n",
        "ORDER BY reading_hour;"
      ]
    },
    {
      "name": "eef65cb2",
      "displayName": "iot device critical conditions monitoring dataset",
      "queryLines": [
        "SELECT\n",
        "    device_id,\n",
        "    reading_ts,\n",
        "    temperature_c,\n",
        "    vibration_hz,\n",
        "    zone_name,\n",
        "    floor,\n",
        "    supervisor\n",
        "FROM iot_krish.gold.critical_alerts;"
      ]
    }
  ],
